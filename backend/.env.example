# Postgres connection for the isolated "crane" database on myserver
DATABASE_URL=postgresql://crane_app:CHANGE_ME@127.0.0.1:5432/crane

# Firebase project the frontend's Google sign-in issues ID tokens for.
# Only used to verify tokens (issuer/audience) - no Firebase SDK/service
# account involved, verification is done against Google's public JWKS.
FIREBASE_PROJECT_ID=gen-lang-client-0595727372

# Browser origins allowed to call the authenticated REST endpoints.
# The device-facing /device/sync endpoint has no CORS restriction (not
# browser-invoked) - only these two matter.
ALLOWED_ORIGINS=https://crane.auralife.uz,http://localhost:3000

PORT=8092
