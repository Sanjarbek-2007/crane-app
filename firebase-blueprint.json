{
  "collections": [
    {
      "name": "devices",
      "fields": {
        "serial_number": "string",
        "name": "string",
        "status": "string",
        "last_seen_at": "number",
        "owner_uid": "string",
        "owner_email": "string",
        "shared_with": "string[]"
      },
      "rules": [
        {
          "allow": "read",
          "condition": "resource.data.owner_uid == request.auth.uid || request.auth.token.email in resource.data.shared_with"
        },
        {
          "allow": "create",
          "condition": "request.auth.uid != null && request.resource.data.owner_uid == request.auth.uid"
        },
        {
          "allow": "update",
          "condition": "resource.data.owner_uid == request.auth.uid || request.auth.token.email in resource.data.shared_with"
        }
      ]
    },
    {
      "name": "logs",
      "fields": {
        "device_id": "string",
        "device_name": "string",
        "action": "string",
        "source": "string",
        "issued_by": "string",
        "created_at": "number",
        "related_emails": "string[]"
      },
      "rules": [
        {
          "allow": "read",
          "condition": "request.auth.token.email in resource.data.related_emails"
        },
        {
          "allow": "create",
          "condition": "request.auth.uid != null && request.auth.token.email in request.resource.data.related_emails"
        }
      ]
    },
    {
      "name": "schedules",
      "fields": {
        "device_id": "string",
        "device_name": "string",
        "action": "string",
        "scheduled_at": "number",
        "status": "string",
        "created_by": "string",
        "related_emails": "string[]"
      },
      "rules": [
        {
          "allow": "read",
          "condition": "request.auth.token.email in resource.data.related_emails"
        },
        {
          "allow": "create, update",
          "condition": "request.auth.uid != null && request.auth.token.email in request.resource.data.related_emails"
        },
        {
          "allow": "delete",
          "condition": "request.auth.token.email in resource.data.related_emails"
        }
      ]
    }
  ]
}
