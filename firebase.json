{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "*.local"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "target": "api",
    "public": "public-api",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/sync",
        "function": {
          "functionId": "deviceSync",
          "region": "us-central1"
        }
      }
    ]
  }
}
