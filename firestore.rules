rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /devices/{deviceId} {
      allow read: if isSignedIn() && (existing().owner_uid == request.auth.uid || (request.auth.token.email in existing().shared_with));
      // Devices are only ever created by claimDeviceCallable (Admin SDK,
      // bypasses these rules) after verifying a provisioned claim code -
      // no direct client create, or any signed-in user could fabricate
      // ownership of an arbitrary serial number.
      allow create: if false;
      allow update: if isSignedIn()
        && (existing().owner_uid == request.auth.uid || (request.auth.token.email in existing().shared_with))
        && incoming().owner_uid == existing().owner_uid
        && incoming().owner_email == existing().owner_email
        && incoming().serial_number == existing().serial_number
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'last_seen_at', 'shared_with', 'name']);
      allow delete: if isSignedIn() && existing().owner_uid == request.auth.uid;
    }

    // Device provisioning secrets - never readable or writable by any
    // client SDK. Only Cloud Functions (Admin SDK, bypasses these rules)
    // touch this collection: provisionDevice.ts writes it, claimDeviceCallable
    // and deviceSync read/update it.
    match /device_secrets/{serial} {
      allow read, write: if false;
    }

    match /logs/{logId} {
      allow read: if isSignedIn() && (request.auth.token.email in resource.data.related_emails);
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /schedules/{scheduleId} {
      allow read: if isSignedIn() && (request.auth.token.email in resource.data.related_emails);
      allow create: if isSignedIn() && (request.auth.token.email in incoming().related_emails);
      allow update: if isSignedIn() && (request.auth.token.email in resource.data.related_emails);
      allow delete: if isSignedIn() && (request.auth.token.email in resource.data.related_emails);
    }
    
    match /{document=**} {
      allow read, write: if false; // default deny
    }
  }
}
